{
  "title": "Disable Cmd+M (Minimize)",
  "rules": [
    {
      "description": "Swallow Cmd+M - Do Nothing",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "m",
            "modifiers": {
              "mandatory": ["command"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "vk_none"
            }
          ],
          "to_if_alone": [
            {
              "key_code": "vk_none"
            }
          ]
        }
      ]
    }
  ]
}
