        },

        {
          "type": "basic",
          "from": { "key_code": "comma", "modifiers": { "optional": ["any"] } },
          "to": [{ "key_code": "comma", "modifiers": ["left_shift"] }],
          "conditions": [{ "type": "variable_if", "name": "symbol_layer", "value": 1 }]
        },
        {
          "type": "basic",
          "from": { "key_code": "period", "modifiers": { "optional": ["any"] } },
          "to": [{ "key_code": "period", "modifiers": ["left_shift"] }],
          "conditions": [{ "type": "variable_if", "name": "symbol_layer", "value": 1 }]
        }

      ]
    }
  ]
}
